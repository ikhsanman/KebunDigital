---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import myImage from '../assets/index-pic.jpg';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Halo, Manusia dan Alam!</h1>
			<Image src={myImage} alt="Rahsan" />
			<p>
				Selamat datang di blog pribadi Gua. Nantinya blog ini akan diisi dengan berbagai tulisan-tulisan tentang apa aja yang gua suka, bisa jadi tentang opini-opini gua mengenai hobi, teknologi, politik, dan lain-lain.
			</p>
			<p>
				Pada akhirnya ini akan jadi semacam taman dari pikiran Gua yang bisa kalian baca kapan aja.
			</p>
		</main>
		<Footer />
	</body>
</html>
